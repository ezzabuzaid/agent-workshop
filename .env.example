# Copy to .env and fill in. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: any OpenRouter model slug. Default below matches the workshop preference.
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# GitHub Personal Access Token (classic or fine-grained, public-repo read scope is enough).
# Used by:
#   - the hand-written GitHub tools in examples 02/03/07 (optional: raises REST rate limits)
#   - the GitHub MCP server in examples 04/06 (REQUIRED)
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Optional: override the GitHub MCP server launch command (defaults to the npx reference server).
# For the official Go server: GITHUB_MCP_CMD=docker  GITHUB_MCP_ARGS=run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN ghcr.io/github/github-mcp-server
# GITHUB_MCP_CMD=npx
# GITHUB_MCP_ARGS=-y @modelcontextprotocol/server-github
